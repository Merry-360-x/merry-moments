{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "merry360x.com"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://merry360x.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.merry360x.com"
        }
      ],
      "destination": "https://merry360x.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    { "source": "/index-:hash.js", "destination": "/assets/index-:hash.js" },
    { "source": "/index-:hash.css", "destination": "/assets/index-:hash.css" },
    { "source": "/api/flutterwave-webhook", "destination": "/api/flutterwave?action=webhook" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, proxy-revalidate" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/review?action=send-emails",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/pawapay-check-status?action=sync-payouts&syncAll=1&limit=100",
      "schedule": "15 4 * * *"
    }
  ]
}

